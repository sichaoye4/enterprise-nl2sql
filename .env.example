# LLM API Configuration
# Primary LLM provider (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# LLM Judge (DashScope/Qwen)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# Alternative: OpenRouter (used by some benchmark scripts)
OPENROUTER_API_KEY=

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/enterprise_nl2sql

# Semantic Model Directory
SEMANTIC_DIR=

# SQL Dialect (spark, postgresql, sqlite)
SQL_DIALECT=sqlite
